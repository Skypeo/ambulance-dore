---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { site } from '../data/site.js';

const {
  title,
  description,
  current = '',
  theme = '',          // '' = bleu (ambulances) ; 'theme-pf' = or (pompes funèbres)
  image = '/og-image.jpg',
} = Astro.props;

const canonical = new URL(Astro.url.pathname, site.domain).href;
const fullTitle = title;

// Bulle de contact flottante — coordonnées selon le pôle de la page
const isPf = theme === 'theme-pf';
const bubblePhone = isPf ? site.pf.phone : site.phoneMain;
const bubblePhoneHref = isPf ? site.pf.phoneHref : site.phoneMainHref;
const bubbleEmail = isPf ? site.pf.email : site.email;
const bubbleEmailHref = isPf ? site.pf.emailHref : `mailto:${site.email}`;
const bubbleContactHref = isPf ? '/contact-pompes-funebres' : '/contact';

// Bouton de bascule entre les deux pôles (bas-gauche). Il porte le logo +
// le nom de l'AUTRE pôle (celui vers lequel on va).
const switchHref = isPf ? '/ambulances' : '/pompes-funebres';
const switchName = isPf ? 'Ambulances Doré' : 'Pompes funèbres';
const switchAria = `Basculer vers le pôle ${isPf ? 'ambulances' : 'pompes funèbres'}`;
---

<!DOCTYPE html>
<html lang="fr" class={theme}>
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <script is:inline>
    // Active le preloader dès le 1er rendu (sauf capture headless / no-JS le saute donc le contenu reste visible)
    if (!(/HeadlessChrome|puppeteer/i.test(navigator.userAgent) || navigator.webdriver)) {
      document.documentElement.classList.add('preloading');
    }
  </script>
  <title>{fullTitle}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:locale" content="fr_FR" />
  <meta property="og:site_name" content="Ambulances Doré" />
  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonical} />
  <meta name="twitter:card" content="summary_large_image" />

  <meta name="theme-color" content="#001f4d" />
  <link rel="icon" href="/favicon.svg" type="image/svg+xml" />

  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Comfortaa:wght@400;500;600;700&family=Cormorant+Garamond:ital,wght@0,500;0,600;0,700;1,500;1,600&family=Montserrat:wght@500;600;700;800;900&display=swap"
    rel="stylesheet"
  />

  <!-- Données structurées entreprise locale -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "EmergencyService",
    "name": "Ambulances Doré",
    "image": canonical + "og-image.jpg",
    "url": site.domain,
    "telephone": "+33254781555",
    "email": site.email,
    "address": {
      "@type": "PostalAddress",
      "streetAddress": site.addressMain.street,
      "postalCode": site.addressMain.zip,
      "addressLocality": site.addressMain.city,
      "addressCountry": "FR"
    },
    "openingHours": "Mo-Su 00:00-23:59",
    "areaServed": "Loir-et-Cher",
    "description": description
  })} />
</head>

<body>
  <div class="preloader" aria-hidden="true">
    <div class="beacon">
      <span class="ring"></span><span class="ring r2"></span><span class="ring r3"></span>
      {isPf ? (
        <img class="beacon-mark is-jenna" src="/images/pf/logo-jenna.webp" alt="" />
      ) : (
        <svg class="beacon-mark" viewBox="0 0 100 100" aria-hidden="true"><path d="M74 50 L94.11 38.39 L82.11 17.61 L62 29.22 L62 6 L38 6 L38 29.22 L17.89 17.61 L5.89 38.39 L26 50 L5.89 61.61 L17.89 82.39 L38 70.78 L38 94 L62 94 L62 70.78 L82.11 82.39 L94.11 61.61 Z" /></svg>
      )}
    </div>
    <span class="preloader-label">Chargement…</span>
  </div>
  <Header current={current} theme={theme} />
  <main>
    <slot />
  </main>
  <Footer theme={theme} />

  <!-- Bouton de bascule entre les deux pôles (bas-gauche) -->
  <a class={`pole-switch${isPf ? ' to-amb' : ' to-pf'}`} href={switchHref} aria-label={switchAria}>
    <span class="ps-logo">
      {isPf ? (
        <svg class="ps-star" viewBox="0 0 100 100" aria-hidden="true"><path d="M74 50 L94.11 38.39 L82.11 17.61 L62 29.22 L62 6 L38 6 L38 29.22 L17.89 17.61 L5.89 38.39 L26 50 L5.89 61.61 L17.89 82.39 L38 70.78 L38 94 L62 94 L62 70.78 L82.11 82.39 L94.11 61.61 Z" /></svg>
      ) : (
        <img src="/images/pf/logo-jenna.webp" alt="" />
      )}
    </span>
    <span class="ps-text">
      <small>Basculer vers le pôle</small>
      <b>{switchName}</b>
    </span>
    <svg class="ps-arrow" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M13 6l6 6-6 6" /></svg>
  </a>

  <!-- Bulle de contact flottante (option de contact anonyme) -->
  <div class="contact-bubble" aria-live="polite">
    <div class="cb-panel" role="dialog" aria-label="Nous contacter">
      <h4>Une question ?</h4>
      <p>Nous sommes à votre écoute. Contactez-nous, ou écrivez-nous sans laisser votre nom.</p>
      <div class="cb-row">
        <a href={bubblePhoneHref}>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.37 1.9.72 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.35 1.85.59 2.81.72A2 2 0 0 1 22 16.92Z" /></svg>
          {bubblePhone}
        </a>
        <a href={bubbleEmailHref}>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="5" width="18" height="14" rx="2"/><path d="m3 7 9 6 9-6"/></svg>
          Écrire un e-mail
        </a>
        <a href={bubbleContactHref}>
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
          Formulaire de contact
        </a>
      </div>
      <p class="cb-anon">Vous pouvez nous écrire de façon anonyme via le formulaire.</p>
    </div>
    <button class="cb-toggle" aria-expanded="false" aria-label="Ouvrir le contact rapide">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/></svg>
      <span>Contact</span>
    </button>
  </div>

  <script is:inline>
    // Détection headless (capture d'écran) — sinon on garde le contenu visible sans JS.
    const isHeadless = /HeadlessChrome|puppeteer/i.test(navigator.userAgent) || navigator.webdriver;
    if (!isHeadless) document.documentElement.classList.add('js');

    // Preloader "beacon" : masqué après chargement (min ~700ms d'affichage), avec garde-fou
    if (document.documentElement.classList.contains('preloading')) {
      const hidePreloader = () => {
        document.documentElement.classList.add('preloader-hidden');
        setTimeout(() => document.documentElement.classList.remove('preloading'), 600);
      };
      const t0 = performance.now();
      window.addEventListener('load', () => {
        setTimeout(hidePreloader, Math.max(0, 700 - (performance.now() - t0)));
      });
      setTimeout(hidePreloader, 4000); // garde-fou si 'load' ne se déclenche pas
    }

    // Menu off-canvas (mobile + tablette)
    const burger = document.querySelector('.nav-burger');
    const drawer = document.querySelector('.nav-drawer');
    const backdrop = document.querySelector('.nav-backdrop');
    const drawerClose = document.querySelector('.drawer-close');
    const openDrawer = () => {
      drawer?.classList.add('open');
      backdrop?.classList.add('open');
      burger?.classList.add('is-open');
      burger?.setAttribute('aria-expanded', 'true');
      drawer?.setAttribute('aria-hidden', 'false');
      document.body.classList.add('drawer-open');
    };
    const closeDrawer = () => {
      drawer?.classList.remove('open');
      backdrop?.classList.remove('open');
      burger?.classList.remove('is-open');
      burger?.setAttribute('aria-expanded', 'false');
      drawer?.setAttribute('aria-hidden', 'true');
      document.body.classList.remove('drawer-open');
    };
    burger?.addEventListener('click', () => {
      drawer?.classList.contains('open') ? closeDrawer() : openDrawer();
    });
    drawerClose?.addEventListener('click', closeDrawer);
    backdrop?.addEventListener('click', closeDrawer);
    drawer?.querySelectorAll('a').forEach((a) => a.addEventListener('click', closeDrawer));
    document.addEventListener('keydown', (ev) => { if (ev.key === 'Escape') closeDrawer(); });

    // Bulle de contact flottante
    const cBubble = document.querySelector('.contact-bubble');
    const cToggle = cBubble?.querySelector('.cb-toggle');
    cToggle?.addEventListener('click', (ev) => {
      ev.stopPropagation();
      const open = cBubble.classList.toggle('open');
      cToggle.setAttribute('aria-expanded', String(open));
    });
    document.addEventListener('click', (ev) => {
      if (cBubble && cBubble.classList.contains('open') && !cBubble.contains(ev.target)) {
        cBubble.classList.remove('open');
        cToggle?.setAttribute('aria-expanded', 'false');
      }
    });

    // Header solidifié au scroll
    const navPill = document.querySelector('header.site .nav-pill');
    window.addEventListener('scroll', () => {
      if (!navPill) return;
      navPill.classList.toggle('scrolled', window.scrollY > 40);
    }, { passive: true });

    // Reveal au scroll
    const revealTargets = document.querySelectorAll(
      '[data-reveal], .stat, .svc, .info-card, .avis-card, .agency, .split-card, .section-head, .media-frame, .prose, .pole, .faq details, .cta-band .inner'
    );
    const io = new IntersectionObserver((entries) => {
      entries.forEach((e) => {
        if (e.isIntersecting) {
          const delay = parseInt(e.target.dataset.revealDelay || '0', 10);
          setTimeout(() => e.target.classList.add('is-visible'), delay);
          io.unobserve(e.target);
        }
      });
    }, { threshold: 0.12, rootMargin: '0px 0px -40px 0px' });
    revealTargets.forEach((t) => {
      if (!t.hasAttribute('data-reveal') && !t.classList.contains('stat')) {
        t.setAttribute('data-reveal', '');
      }
      io.observe(t);
    });

    // Décalages d'apparition pour les grilles
    document.querySelectorAll('.services-grid .svc').forEach((el, i) => (el.dataset.revealDelay = i * 80));
    document.querySelectorAll('.cards-grid .info-card').forEach((el, i) => (el.dataset.revealDelay = i * 80));
    document.querySelectorAll('.avis-grid .avis-card').forEach((el, i) => (el.dataset.revealDelay = i * 120));
    document.querySelectorAll('.agencies-grid .agency').forEach((el, i) => (el.dataset.revealDelay = i * 140));

    // Sécurité : tout afficher après 1.2s si jamais un élément n'est pas observé
    setTimeout(() => {
      document.querySelectorAll('[data-reveal]:not(.is-visible), .stat:not(.is-visible)').forEach((el) => {
        const r = el.getBoundingClientRect();
        if (r.top < window.innerHeight + 200) el.classList.add('is-visible');
      });
    }, 1200);

    // Compteurs animés
    const counters = document.querySelectorAll('[data-count]');
    const cIo = new IntersectionObserver((entries) => {
      entries.forEach((e) => {
        if (!e.isIntersecting) return;
        const el = e.target;
        const target = el.dataset.count;
        const suffix = el.dataset.suffix || '';
        cIo.unobserve(el);
        if (target.includes('/')) { el.textContent = target; return; }
        const end = parseInt(target, 10);
        const dur = 1400;
        const start = performance.now();
        const step = (now) => {
          const p = Math.min((now - start) / dur, 1);
          const eased = 1 - Math.pow(1 - p, 3);
          el.textContent = Math.floor(eased * end) + suffix;
          if (p < 1) requestAnimationFrame(step);
          else el.textContent = end + suffix;
        };
        requestAnimationFrame(step);
      });
    }, { threshold: 0.4 });
    counters.forEach((c) => cIo.observe(c));

    // Tilt 3D sur les cartes services (desktop)
    if (matchMedia('(hover:hover)').matches) {
      document.querySelectorAll('.svc').forEach((card) => {
        card.addEventListener('mousemove', (ev) => {
          const r = card.getBoundingClientRect();
          const cx = (ev.clientX - r.left) / r.width - 0.5;
          const cy = (ev.clientY - r.top) / r.height - 0.5;
          card.style.transform = `translateY(-8px) rotateX(${-cy * 4}deg) rotateY(${cx * 6}deg)`;
        });
        card.addEventListener('mouseleave', () => { card.style.transform = ''; });
      });
    }
  </script>
</body>
</html>
