---
// Visuel de contenu. Si `src` est fourni → vraie image (cadre media-frame).
// Sinon → placeholder thématisé "Visuel à venir" (utilisé tant qu'on n'a pas de photo).
const { label = 'Visuel à venir', extraClass = '', src = '', alt = '' } = Astro.props;
---
{src ? (
  <figure class={`media-frame ${extraClass}`} data-reveal>
    <img src={src} alt={alt} loading="lazy" decoding="async" />
  </figure>
) : (
  <div class={`media-frame placeholder ${extraClass}`} data-reveal>
    <div class="ph-inner">
      <span class="ph-hex">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
          <rect x="3" y="6" width="18" height="14" rx="2" />
          <circle cx="12" cy="13" r="3.5" />
          <path d="M8 6l1.5-2h5L16 6" />
        </svg>
      </span>
      <span class="ph-label">{label}</span>
    </div>
  </div>
)}
