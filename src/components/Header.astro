---
import { navAmb, navPf, site } from '../data/site.js';
import logo from '../assets/logo-440w.webp';
const { current = '', theme = '' } = Astro.props;
const isPf = theme === 'theme-pf';
// Chaque pôle a SA navbar (plus de sous-menu croisé). La bascule se fait
// via le bouton flottant `.pole-switch` (cf. Base.astro) + le portail "/".
const nav = isPf ? navPf : navAmb;
// Le logo ramène à la home du pôle courant (pas au portail "/").
const homeHref = isPf ? '/pompes-funebres' : '/ambulances';
// La page Contact suit le pôle courant (formulaire différent par pôle).
const contactHref = isPf ? '/contact-pompes-funebres' : '/contact';

// Marque un item actif. Les dropdowns s'allument sur leurs sous-liens
// uniquement (pas sur leur href racine, qui = la home du pôle) pour éviter
// un double-actif "Accueil" + dropdown sur la home.
function isActive(item) {
  if (item.groups) {
    return item.href === current || item.groups.some((g) => g.links.some((l) => l.href === current));
  }
  if (item.href === '/contact' || item.href === '/contact-pompes-funebres') {
    return current === '/contact' || current === '/contact-pompes-funebres';
  }
  return current === item.href;
}
---

<header class="site">
  <div class="container">
    <div class="nav-pill">
      <a href={homeHref} class="nav-logo" aria-label={isPf ? 'Pompes Funèbres Jenna — accueil' : 'Ambulances Doré — accueil'}>
        {isPf ? (
          <img src="/images/pf/logo-philae.webp" alt="Pompes Funèbres Jenna" />
        ) : (
          <img src={logo.src} width={logo.width} height={logo.height} alt="Ambulances Doré" />
        )}
      </a>

      <nav class="nav-links" aria-label="Navigation principale">
        {nav.map((item) =>
          item.hasSub ? (
            <div class="nav-item">
              <a
                href={item.href}
                class="has-sub"
                aria-current={isActive(item) ? 'page' : undefined}
              >
                {item.label}
              </a>
              <div class={`nav-submenu${item.pf ? ' pf' : ''}`}>
                {item.groups.map((g) => (
                  <>
                    <span class="sub-group">{g.title}</span>
                    {g.links.map((l) => (
                      <a href={l.href} aria-current={current === l.href ? 'page' : undefined}>
                        {l.label}
                      </a>
                    ))}
                  </>
                ))}
              </div>
            </div>
          ) : (
            <a href={item.href} aria-current={isActive(item) ? 'page' : undefined}>
              {item.label}
            </a>
          )
        )}
      </nav>

      <button class="nav-burger" aria-label="Ouvrir le menu" aria-expanded="false" aria-controls="nav-drawer">
        <span class="burger-ico" aria-hidden="true">
          <span class="bar top"></span>
          <span class="bar middle"></span>
          <span class="bar bottom"></span>
        </span>
      </button>

      {isPf && (
        <a href={site.pf.instagram} class="nav-ig" target="_blank" rel="noopener noreferrer" aria-label="Instagram — Pompes Funèbres Jenna">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
        </a>
      )}

      {isPf && (
        <a href={site.pf.linkedin} class="nav-ig nav-li" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn — Pompes Funèbres Jenna">
          <svg viewBox="0 0 24 24" fill="currentColor"><path d="M19 3a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h14zM8.34 9.5H5.67V18h2.67V9.5zM7 6.13a1.55 1.55 0 1 0 0 3.1 1.55 1.55 0 0 0 0-3.1zM18.33 18v-4.67c0-2.48-1.32-3.63-3.09-3.63a2.66 2.66 0 0 0-2.41 1.33h-.04V9.5h-2.56V18h2.67v-4.2c0-1.11.21-2.18 1.58-2.18 1.35 0 1.37 1.26 1.37 2.25V18h2.5z"/></svg>
        </a>
      )}

      {isPf && (
        <a href={site.pf.facebook} class="nav-ig nav-li" target="_blank" rel="noopener noreferrer" aria-label="Facebook — Pompes Funèbres Jenna">
          <svg viewBox="0 0 24 24" fill="currentColor"><path d="M22 12.06C22 6.5 17.52 2 12 2S2 6.5 2 12.06c0 5 3.66 9.15 8.44 9.94v-7.03H7.9v-2.91h2.54V9.85c0-2.51 1.49-3.9 3.78-3.9 1.09 0 2.24.2 2.24.2v2.46h-1.26c-1.24 0-1.63.78-1.63 1.57v1.88h2.78l-.44 2.91h-2.34V22c4.78-.79 8.44-4.94 8.44-9.94z"/></svg>
        </a>
      )}

      <a href={contactHref} class="nav-cta nav-cta-desktop">
        {isPf ? 'Nous contacter' : 'Réserver'}
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
          <path d="M5 12h14M13 6l6 6-6 6" />
        </svg>
      </a>
    </div>
  </div>

  <!-- Menu off-canvas (mobile + tablette ≤1080px) — repris du pôle courant -->
  <div class="nav-backdrop" aria-hidden="true"></div>
  <aside id="nav-drawer" class={`nav-drawer${isPf ? ' is-pf' : ''}`} aria-label="Menu de navigation" aria-hidden="true">
    <div class="drawer-head">
      <a href={homeHref} class="drawer-logo" aria-label={isPf ? 'Pompes Funèbres Jenna — accueil' : 'Ambulances Doré — accueil'}>
        {isPf ? (
          <img src="/images/pf/logo-philae.webp" alt="Pompes Funèbres Jenna" />
        ) : (
          <img src={logo.src} width={logo.width} height={logo.height} alt="Ambulances Doré" />
        )}
      </a>
      <button class="drawer-close" aria-label="Fermer le menu">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round"><path d="M6 6l12 12M18 6L6 18" /></svg>
      </button>
    </div>

    <nav class="drawer-nav" aria-label="Navigation mobile">
      {nav.map((item) =>
        item.hasSub ? (
          <div class="drawer-group">
            <a href={item.href} class="drawer-link" aria-current={isActive(item) ? 'page' : undefined}>{item.label}</a>
            {item.groups.map((g) => (
              <div class="drawer-sub">
                <span class="drawer-sub-title">{g.title}</span>
                {g.links.map((l) => (
                  <a href={l.href} class="drawer-sublink" aria-current={current === l.href ? 'page' : undefined}>{l.label}</a>
                ))}
              </div>
            ))}
          </div>
        ) : (
          <a href={item.href} class="drawer-link" aria-current={isActive(item) ? 'page' : undefined}>{item.label}</a>
        )
      )}
    </nav>

    <a href={contactHref} class="drawer-cta">
      {isPf ? 'Nous contacter' : 'Réserver'}
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M5 12h14M13 6l6 6-6 6" /></svg>
    </a>

    {isPf && (
      <a href={site.pf.instagram} class="drawer-ig" target="_blank" rel="noopener noreferrer">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
        Suivez-nous sur Instagram
      </a>
    )}

    {isPf && (
      <a href={site.pf.linkedin} class="drawer-ig drawer-li" target="_blank" rel="noopener noreferrer">
        <svg viewBox="0 0 24 24" fill="currentColor"><path d="M19 3a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h14zM8.34 9.5H5.67V18h2.67V9.5zM7 6.13a1.55 1.55 0 1 0 0 3.1 1.55 1.55 0 0 0 0-3.1zM18.33 18v-4.67c0-2.48-1.32-3.63-3.09-3.63a2.66 2.66 0 0 0-2.41 1.33h-.04V9.5h-2.56V18h2.67v-4.2c0-1.11.21-2.18 1.58-2.18 1.35 0 1.37 1.26 1.37 2.25V18h2.5z"/></svg>
        Suivez-nous sur LinkedIn
      </a>
    )}

    {isPf && (
      <a href={site.pf.facebook} class="drawer-ig drawer-li" target="_blank" rel="noopener noreferrer">
        <svg viewBox="0 0 24 24" fill="currentColor"><path d="M22 12.06C22 6.5 17.52 2 12 2S2 6.5 2 12.06c0 5 3.66 9.15 8.44 9.94v-7.03H7.9v-2.91h2.54V9.85c0-2.51 1.49-3.9 3.78-3.9 1.09 0 2.24.2 2.24.2v2.46h-1.26c-1.24 0-1.63.78-1.63 1.57v1.88h2.78l-.44 2.91h-2.34V22c4.78-.79 8.44-4.94 8.44-9.94z"/></svg>
        Suivez-nous sur Facebook
      </a>
    )}
  </aside>
</header>
