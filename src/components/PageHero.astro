---
import HeroMesh from './HeroMesh.astro';
const {
  eyebrow,
  title,        // peut contenir du HTML (ex: <em>)
  lead,
  crumbs = [],  // [{label, href}] — dernier = page courante
  ctaLabel = 'Réserver un transport',
  ctaHref = '/contact',
  brandLogo = '',   // src d'un logo co-marque (ex: Pompes Funèbres Jenna)
  brandAlt = '',
  slogan = '',      // accroche en italique sous le titre (ex: slogan Jenna)
} = Astro.props;
---
<section class="page-hero">
  <HeroMesh />
  <div class="container">
    <div class="page-hero-inner" data-reveal>
      {crumbs.length > 0 && (
        <nav class="breadcrumb" aria-label="Fil d'Ariane">
          <a href="/">Accueil</a>
          {crumbs.map((c, i) => (
            <>
              <span class="sep">/</span>
              {c.href && i < crumbs.length - 1 ? (
                <a href={c.href}>{c.label}</a>
              ) : (
                <span aria-current="page">{c.label}</span>
              )}
            </>
          ))}
        </nav>
      )}
      {brandLogo && (
        <span class="hero-brand">
          <img src={brandLogo} alt={brandAlt} loading="eager" decoding="async" />
        </span>
      )}
      {eyebrow && <div class="eyebrow">{eyebrow}</div>}
      <h1 set:html={title}></h1>
      {slogan && <p class="hero-slogan">{slogan}</p>}
      {lead && <p class="lead">{lead}</p>}
      <div class="hero-cta-row">
        <a href={ctaHref} class="btn-primary">
          {ctaLabel}
          <span class="arrow">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M5 12h14M13 6l6 6-6 6" /></svg>
          </span>
        </a>
        <slot name="cta" />
      </div>
    </div>
  </div>
</section>
