---
import Base from '../layouts/Base.astro';
import PageHero from '../components/PageHero.astro';
import CtaBand from '../components/CtaBand.astro';
import { site } from '../data/site.js';

// Page d'aperçu de la catégorie "Nos accompagnements" (regroupe les pages
// organisation des obsèques, contrat obsèques, retour à domicile).
// Objectif SEO : page de présentation des services d'accompagnement funéraire à Blois.
const title = "Nos accompagnements funéraires à Blois | Pompes Funèbres Jenna";
const description =
  "Pompes Funèbres Jenna à Blois vous accompagne à chaque étape : organisation d'obsèques personnalisées, contrat de prévoyance obsèques et retour du défunt à domicile. Écoute, respect et disponibilité 24h/24, 7j/7.";

const accompagnements = [
  {
    href: '/organisation-obseques',
    title: "Organisation des obsèques",
    text: "Des obsèques à votre image : cérémonie personnalisée, textes, musiques et rituels, fleurs et hommages. Nous coordonnons chaque détail et toutes les démarches administratives.",
    icon: '<path d="M12 21s-7-4.5-9.5-9A5 5 0 0 1 12 6a5 5 0 0 1 9.5 6c-2.5 4.5-9.5 9-9.5 9z"/>',
  },
  {
    href: '/contrat-obseques',
    title: "Contrat obsèques",
    text: "Prévoir, c'est protéger. Organisez et financez vos funérailles à l'avance pour soulager vos proches et garantir le respect de vos volontés.",
    icon: '<path d="M9 11l3 3L22 4M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/>',
  },
  {
    href: '/retour-a-domicile',
    title: "Retour à domicile",
    text: "Une alternative souvent méconnue : présenter le défunt dans un cadre familier, pour un dernier hommage intime, entouré des siens.",
    icon: '<path d="M3 10.5 12 3l9 7.5M5 9v11h14V9"/><path d="M10 20v-5h4v5"/>',
  },
];

const ldJson = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "BreadcrumbList",
      "itemListElement": [
        { "@type": "ListItem", "position": 1, "name": "Pompes funèbres", "item": site.domain + "/pompes-funebres" },
        { "@type": "ListItem", "position": 2, "name": "Nos accompagnements", "item": site.domain + "/nos-accompagnements" },
      ],
    },
    {
      "@type": "ItemList",
      "name": "Accompagnements funéraires — Pompes Funèbres Jenna",
      "itemListElement": accompagnements.map((a, i) => ({
        "@type": "ListItem",
        "position": i + 1,
        "name": a.title,
        "url": site.domain + a.href,
      })),
    },
  ],
};
---
<Base title={title} description={description} current="/nos-accompagnements" theme="theme-pf">
  <PageHero
    eyebrow="Pompes Funèbres Jenna — Blois"
    title="Nos accompagnements<br><em>funéraires</em>."
    slogan="À vos côtés, à chaque étape."
    lead="De l'organisation des obsèques à la prévoyance, en passant par le retour du défunt à domicile, nous accompagnons les familles de Blois et de ses environs avec écoute, respect et discrétion."
    crumbs={[{ label: 'Pompes funèbres', href: '/pompes-funebres' }, { label: 'Nos accompagnements' }]}
    ctaLabel="Être accompagné·e"
    ctaHref="/contact-pompes-funebres"
    brandLogo="/images/pf/logo-philae.webp"
    brandAlt="Pompes Funèbres Jenna"
    heroImage="/images/pf/accueil.webp"
    heroImageAlt="Salon d'accueil des Pompes Funèbres Jenna à Blois : un espace chaleureux pour recevoir les familles"
    tree
  >
    <a slot="cta" href={site.pf.phoneHref} class="btn-call">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.37 1.9.72 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.35 1.85.59 2.81.72A2 2 0 0 1 22 16.92Z" /></svg>
      {site.pf.phone}
    </a>
  </PageHero>

  <section class="section plain">
    <div class="container">
      <div class="prose" data-reveal style="max-width:760px;margin:0 auto;text-align:center">
        <div class="eyebrow" style="justify-content:center">Un interlocuteur unique</div>
        <h2>Vous épauler dans <em>chaque démarche</em>.</h2>
        <p class="lead-p">Perdre un proche bouleverse une famille. Les Pompes Funèbres Jenna (Philae Services Funéraires), agence funéraire de proximité à Blois, prennent le temps d'écouter, d'expliquer et d'organiser, pour que vous puissiez vous concentrer sur l'essentiel.</p>
        <p>Découvrez nos accompagnements : l'organisation complète des obsèques, le contrat de prévoyance pour anticiper sereinement, et le retour du défunt à domicile pour un dernier hommage dans l'intimité.</p>
      </div>
    </div>
  </section>

  <section class="section warm">
    <div class="container">
      <div class="section-head">
        <div><div class="eyebrow">Nos accompagnements</div><h2>Trois manières de vous <em>soutenir</em>.</h2></div>
        <p>Cliquez sur un accompagnement pour en savoir plus.</p>
      </div>
      <div class="cards-grid">
        {accompagnements.map((a) => (
          <a class="info-card" href={a.href}>
            <div class="ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" set:html={a.icon} /></div>
            <h3>{a.title}</h3>
            <p>{a.text}</p>
            <span class="card-more">En savoir plus
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14M13 6l6 6-6 6"/></svg>
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section plain">
    <div class="container">
      <div class="section-head"><div><div class="eyebrow">Zone desservie</div><h2>Notre <em>rayon d'action</em>.</h2></div><p>Une agence funéraire de proximité, à Blois et dans les communes alentour.</p></div>
      <div class="split-card light" data-reveal>
        <div class="eyebrow">Communes desservies</div>
        <h3>Pompes Funèbres Jenna intervient à Blois et alentours</h3>
        <p>Nous accompagnons les familles de Blois et de tout le secteur. Où que vous soyez, n'hésitez pas à nous contacter.</p>
        <div class="places">
          <span class="chip">Blois</span><span class="chip">Vineuil</span><span class="chip">Chambord</span><span class="chip">La Chaussée-Saint-Victor</span><span class="chip">Mer</span><span class="chip">et ses alentours</span>
        </div>
      </div>
    </div>
  </section>

  <CtaBand
    motif="tree"
    title="Parlons-en, en toute sérénité."
    text="Nos conseillers funéraires vous reçoivent et vous accompagnent dans toutes les démarches, avec écoute et sans précipitation. Astreinte décès 24h/24, 7j/7."
    phone={site.pf.phone}
    phoneHref={site.pf.phoneHref}
    ctaLabel="Nous contacter"
    ctaHref="/contact-pompes-funebres"
  />

  <script type="application/ld+json" set:html={JSON.stringify(ldJson)} />
</Base>
