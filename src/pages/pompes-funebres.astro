---
import Base from '../layouts/Base.astro';
import PageHero from '../components/PageHero.astro';
import CtaBand from '../components/CtaBand.astro';
import Figure from '../components/Figure.astro';
import { site } from '../data/site.js';

// Contenu repris des flyers Jenna (retours cliente du 2026-06-16).
// TODO_CLIENT : noms/parcours des intervenants à compléter (section « Notre équipe »).
const title = "Pompes Funèbres Jenna à Blois — Organisation d'obsèques | Ambulances Doré";
const description =
  "Pompes Funèbres Jenna (Philae Services Funéraires) à Blois : organisation d'obsèques personnalisées, contrat de prévoyance, marbrerie et accompagnement humain. Astreinte décès 24h/24, 7j/7.";

const prises = [
  'Les démarches administratives',
  "L'organisation complète des obsèques",
  'La coordination avec les différents intervenants',
  'Le rapatriement national et international',
  'Les travaux de marbrerie (conception, fabrication, pose)',
  'Les contrats de prévoyance obsèques',
  "La vente d'articles funéraires personnalisés",
];
---
<Base title={title} description={description} current="/pompes-funebres" theme="theme-pf">
  <PageHero
    eyebrow="Pompes Funèbres Jenna — Blois"
    title="L'art du funéraire, c'est l'art du <em>détail</em>."
    slogan="À vos côtés, avec respect et humanité."
    lead="Pompes Funèbres Jenna (Philae Services Funéraires), agence funéraire de proximité à Blois. Parce qu'un décès bouleverse une famille, nous prenons le temps d'écouter, d'expliquer et d'accompagner chaque situation."
    crumbs={[{ label: 'Pompes funèbres' }]}
    ctaLabel="Être accompagné·e"
    ctaHref="/contact-pompes-funebres"
    brandLogo="/images/pf/logo-philae.webp"
    brandAlt="Pompes Funèbres Jenna"
    heroImage="/images/pf/hero-jenna.webp"
    heroImageAlt="Bougie allumée, bouquet de lys et roses blanches et carte « Se souvenir, c'est continuer à aimer »"
    tree
  >
    <a slot="cta" href={site.pf.phoneHref} class="btn-call">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.37 1.9.72 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.35 1.85.59 2.81.72A2 2 0 0 1 22 16.92Z" /></svg>
      {site.pf.phone}
    </a>
  </PageHero>

  <!-- Valeurs Jenna -->
  <section class="pf-values-band">
    <div class="container">
      <ul class="pf-values">
        <li>
          <span class="pf-v-ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M11 14h2a2 2 0 1 0 0-4h-3c-.6 0-1.1.2-1.4.6L3 16"/><path d="m7 20 1.6-1.4c.3-.4.8-.6 1.4-.6h4c1.1 0 2.1-.4 2.8-1.2l4.6-4.4a2 2 0 0 0-2.75-2.91l-4.2 3.9"/><path d="m2 15 6 6"/><path d="M19.5 8.5c.7-.7 1.5-1.6 1.5-2.7A2.73 2.73 0 0 0 16 4a2.78 2.78 0 0 0-5 1.8c0 1.2.8 2 1.5 2.8L16 12Z"/></svg></span>
          <strong>Écoute</strong><span>Nous sommes à votre écoute pour comprendre vos besoins et vos attentes.</span>
        </li>
        <li>
          <span class="pf-v-ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="5" r="3"/><path d="M4.5 21v-1a7.5 7.5 0 0 1 15 0v1"/><path d="M12 17.8c-1.9-1.3-2.9-2.2-2.9-3.4 0-1 .8-1.7 1.7-1.7.6 0 1 .3 1.2.8.2-.5.6-.8 1.2-.8.9 0 1.7.7 1.7 1.7 0 1.2-1 2.1-2.9 3.4z"/></svg></span>
          <strong>Respect</strong><span>Nous honorons chaque histoire, chaque croyance et chaque choix avec respect.</span>
        </li>
        <li>
          <span class="pf-v-ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><rect x="3.5" y="10.5" width="17" height="11" rx="2.2"/><path d="M7 10.5V7a5 5 0 0 1 10 0v3.5"/></svg></span>
          <strong>Discrétion</strong><span>Nous agissons avec discrétion et délicatesse à chaque étape de nos services.</span>
        </li>
        <li>
          <span class="pf-v-ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg></span>
          <strong>Soutien</strong><span>Nous vous apportons un soutien sincère et chaleureux dans les moments difficiles.</span>
        </li>
      </ul>
    </div>
  </section>

  <section class="section plain">
    <div class="container">
      <div class="prose-grid">
        <div class="prose" data-reveal="left">
          <div class="eyebrow">Notre approche</div>
          <h2>Un accompagnement <em>humain et bienveillant</em>.</h2>
          <p class="lead-p">Chez PF Jenna, chaque famille est unique. Nous mettons tout en œuvre pour vous offrir un accompagnement personnalisé, empreint d'humanité, de respect et de bienveillance.</p>
          <p>Parce qu'un décès bouleverse une famille, nous prenons le temps d'écouter, d'expliquer et d'accompagner chaque situation avec respect et discrétion.</p>
          <ul class="ticks">
            <li>Une écoute bienveillante pour comprendre vos besoins et vos attentes</li>
            <li>Le respect de chaque histoire, de chaque croyance et de chaque choix</li>
            <li>Discrétion et soutien à chaque étape de nos services</li>
          </ul>
        </div>
        <Figure src="/images/pf/humain.webp" alt="Bougie, bouquet de lys blancs et cadre « À vos côtés avec respect et humanité »" />
      </div>
    </div>
  </section>

  <section class="section warm">
    <div class="container">
      <div class="section-head">
        <div><div class="eyebrow">Nos accompagnements</div><h2>Un interlocuteur unique, à <em>chaque étape</em>.</h2></div>
        <p>De l'organisation à la cérémonie, de la prévoyance à la marbrerie.</p>
      </div>
      <div class="cards-grid">
        <a class="info-card" href="/organisation-obseques"><div class="ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 21s-7-4.5-9.5-9A5 5 0 0 1 12 6a5 5 0 0 1 9.5 6c-2.5 4.5-9.5 9-9.5 9z"/></svg></div><h3>Organisation des obsèques</h3><p>Des obsèques à votre image : cérémonie, textes, musiques et rituels personnalisés.</p></a>
        <a class="info-card" href="/contrat-obseques"><div class="ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 11l3 3L22 4M21 12v7a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11"/></svg></div><h3>Contrat obsèques</h3><p>Prévoir, c'est protéger : organisez et financez vos funérailles à l'avance.</p></a>
        <a class="info-card" href="/marbrerie"><div class="ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 21V8l7-5 7 5v13M9 21v-6h6v6"/></svg></div><h3>Marbrerie</h3><p>Au cas par cas : monuments simples comme doubles, granit ou pierre naturelle, rechampissage et redorure des gravures.</p></a>
        <a class="info-card" href="/retour-a-domicile"><div class="ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 10.5 12 3l9 7.5M5 9v11h14V9"/><path d="M10 20v-5h4v5"/></svg></div><h3>Retour à domicile</h3><p>Une alternative souvent méconnue : présenter le défunt dans un cadre familier.</p></a>
        <a class="info-card" href="/articles-funeraires"><div class="ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2C8 6 8 10 12 14c4-4 4-8 0-12zM5 14c2 4 5 6 7 6s5-2 7-6"/></svg></div><h3>Articles funéraires</h3><p>Cercueils, urnes, fleurs et plaques pour un hommage fidèle et personnalisé.</p></a>
        <a class="info-card" href="/contact-pompes-funebres"><div class="ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"/></svg></div><h3>Nous contacter</h3><p>Une équipe à votre écoute, dans nos locaux ou au sein de votre structure.</p></a>
      </div>
    </div>
  </section>

  <section class="section plain">
    <div class="container">
      <div class="prose-grid reverse">
        <Figure src="/images/pf/etapes.webp" alt="Cadre « À vos côtés avec respect et humanité », lys blancs et bougie" />
        <div class="prose" data-reveal="right">
          <div class="eyebrow">Accompagnés, à chaque étape</div>
          <h2>Nous prenons <em>tout en charge</em>.</h2>
          <p class="lead-p">PF Jenna vous accompagne avec bienveillance pour prendre en charge toutes les démarches et vous permettre de vous concentrer sur l'essentiel.</p>
          <ul class="ticks">
            {prises.map((p) => <li>{p}</li>)}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- Notre équipe — côté humain (prénoms + parcours) -->
  <section class="section warm">
    <div class="container">
      <div class="section-head">
        <div><div class="eyebrow">Le côté humain</div><h2>Celles et ceux qui vous <em>accompagnent</em>.</h2></div>
        <p>Des visages, des prénoms : derrière chaque accompagnement, une équipe à votre écoute.</p>
      </div>
      <!-- TODO_CLIENT : remplacer par les vrais intervenants (prénom + parcours + photo) -->
      <div class="pf-team">
        <article class="pf-member">
          <span class="pf-avatar" aria-hidden="true">PF</span>
          <h3>Notre équipe</h3>
          <p class="pf-role">Conseillers funéraires</p>
          <p>Une équipe formée et disponible, qui vous reçoit avec écoute et discrétion, à chaque étape du parcours.</p>
        </article>
        <article class="pf-member is-pending">
          <span class="pf-avatar" aria-hidden="true">+</span>
          <h3>Présentations à venir</h3>
          <p class="pf-role">Prénoms &amp; parcours</p>
          <p>Les présentations détaillées de chaque membre de l'équipe seront ajoutées prochainement.</p>
        </article>
      </div>
    </div>
  </section>

  <!-- Respect de toutes les croyances -->
  <section class="section plain">
    <div class="container">
      <div class="pf-faiths">
        <div class="pf-faiths-text">
          <div class="eyebrow">Toutes les croyances</div>
          <h2>Le respect de <em>chaque rite</em>.</h2>
          <p>Quelle que soit votre confession ou votre tradition, nous organisons des obsèques dans le respect de vos rites et de vos volontés — y compris l'accompagnement des familles de confession musulmane.</p>
        </div>
        <ul class="pf-faiths-icons" aria-label="Respect de toutes les confessions">
          <li title="Confession chrétienne"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"><path d="M12 2.5v19M6.5 8.5h11"/></svg></li>
          <li title="Confession musulmane"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"><path d="M16.2 3.4a9 9 0 1 0 0 17.2 7.3 7.3 0 0 1 0-17.2z"/><path d="M18.2 6.4 18.82 8.15 20.67 8.2 19.2 9.32 19.73 11.1 18.2 10.05 16.67 11.1 17.2 9.32 15.73 8.2 17.58 8.15Z" fill="currentColor" stroke="none"/></svg></li>
          <li title="Confession juive"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linejoin="round"><path d="M12 3 20.5 18 3.5 18Z"/><path d="M12 21 3.5 6 20.5 6Z"/></svg></li>
          <li title="Cérémonie civile"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 21s-7-4.5-9.5-9A5 5 0 0 1 12 6a5 5 0 0 1 9.5 6c-2.5 4.5-9.5 9-9.5 9z"/></svg></li>
        </ul>
      </div>
    </div>
  </section>

  <!-- Agence Jenna -->
  <section class="section warm">
    <div class="container">
      <div class="agencies-grid single">
        <article class="agency agency-pf">
          <div class="info">
            <span class="agency-tag">Notre agence funéraire</span>
            <h3>{site.pf.name}</h3>
            <p class="addr">{site.pf.legalName}<br />{site.pf.address.street}<br />{site.pf.address.zip} {site.pf.address.city}</p>
            <a href={site.pf.phoneHref} class="tel-big"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.37 1.9.72 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.35 1.85.59 2.81.72A2 2 0 0 1 22 16.92Z" /></svg>{site.pf.phone}</a>
            <a href={site.pf.emailHref} class="agency-mail">{site.pf.email}</a>
            <div class="hours-table">
              {site.pf.hours.map((row) => (<div class="hr"><span>{row.d}</span><b>{row.h}</b></div>))}
              <div class="hr oncall"><span>{site.pf.onCall}</span></div>
            </div>
          </div>
          <div class="map-side">
            <iframe title="Carte — Pompes Funèbres Jenna, Blois" loading="lazy" src="https://maps.google.com/maps?q=76%20Avenue%20de%20Vend%C3%B4me%2041000%20Blois&output=embed"></iframe>
          </div>
        </article>
      </div>
    </div>
  </section>

  <!-- Recrutement -->
  <section class="section plain">
    <div class="container">
      <div class="pf-recruit" data-reveal>
        <div class="pf-recruit-ico" aria-hidden="true"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M19 8v6M22 11h-6"/></svg></div>
        <div class="pf-recruit-text">
          <div class="eyebrow">Recrutement</div>
          <h2>Constituez avec nous <em>l'équipe funéraire de demain</em>.</h2>
          <p>Les Pompes Funèbres Jenna développent actuellement leur réseau de porteurs, maîtres de cérémonie et agents funéraires afin de répondre aux besoins des familles avec professionnalisme et humanité.</p>
          <p>Vous souhaitez donner du sens à votre engagement professionnel et intervenir de manière ponctuelle ou régulière dans le secteur funéraire ? Nous serions heureux d'échanger avec vous.</p>
        </div>
        <a href={site.pf.emailHref} class="btn-ghost">Nous écrire</a>
      </div>
    </div>
  </section>

  <CtaBand
    motif="tree"
    title="Nous sommes à vos côtés, jour et nuit."
    text="Astreinte décès 24h/24, 7j/7. Nos conseillers funéraires répondent à vos questions et vous accompagnent dans toutes les démarches."
    phone={site.pf.phone}
    phoneHref={site.pf.phoneHref}
    ctaLabel="Nous contacter"
    ctaHref="/contact-pompes-funebres"
  />
</Base>
