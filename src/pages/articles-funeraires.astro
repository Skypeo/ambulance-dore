---
import Base from '../layouts/Base.astro';
import PageHero from '../components/PageHero.astro';
import CtaBand from '../components/CtaBand.astro';
import Figure from '../components/Figure.astro';
import { site } from '../data/site.js';

// TODO_CLIENT : contenu provisoire (lorem) — en attente des textes du client.
const title = "Articles funéraires — Cercueils, urnes, fleurs | Pompes funèbres Doré";
const description =
  "Un large choix d'articles funéraires personnalisables : cercueils, urnes, plaques, fleurs et capitons. Un conseil attentif pour rendre un dernier hommage fidèle.";
---
<Base title={title} description={description} current="/articles-funeraires" theme="theme-pf">
  <PageHero
    eyebrow="Pôle funéraire"
    title="Des articles funéraires <em>personnalisables</em>."
    lead="Cercueils, urnes, plaques, fleurs : un choix soigné pour un hommage fidèle à l'être cher."
    crumbs={[{ label: 'Pompes funèbres', href: '/pompes-funebres' }, { label: 'Articles funéraires' }]}
  />

  <section class="section plain">
    <div class="container">
      <div class="prose-grid">
        <div class="prose" data-reveal="left">
          <h2>Un hommage <em>à votre image</em>.</h2>
          <p class="lead-p">Lorem ipsum dolor sit amet, consectetur adipiscing elit, sed do eiusmod tempor incididunt.</p>
          <p>Ut labore et dolore magna aliqua. Ut enim ad minim veniam, quis nostrud exercitation ullamco laboris. Nous vous présentons l'ensemble de nos articles et vous conseillons sans précipitation.</p>
        </div>
        <Figure label="Visuel à venir" />
      </div>
    </div>
  </section>

  <section class="section warm">
    <div class="container">
      <div class="section-head"><div><div class="eyebrow">Notre sélection</div><h2>Tout pour un <em>dernier hommage</em>.</h2></div><p>Duis aute irure dolor in reprehenderit in voluptate velit esse cillum.</p></div>
      <div class="cards-grid">
        <div class="info-card"><div class="ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><rect x="4" y="3" width="16" height="18" rx="1"/><path d="M9 8h6"/></svg></div><h3>Cercueils</h3><p>Lorem ipsum dolor sit amet, consectetur adipiscing elit.</p></div>
        <div class="info-card"><div class="ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M8 21h8M9 3h6l-1 6a3 3 0 0 1-4 0z"/><path d="M7 9a5 5 0 0 0 10 0"/></svg></div><h3>Urnes</h3><p>Sed do eiusmod tempor incididunt ut labore et dolore.</p></div>
        <div class="info-card"><div class="ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M12 2C8 6 8 10 12 14c4-4 4-8 0-12zM5 14c2 4 5 6 7 6s5-2 7-6"/></svg></div><h3>Fleurs & couronnes</h3><p>Magna aliqua ut enim ad minim veniam quis nostrud.</p></div>
        <div class="info-card"><div class="ico"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><rect x="3" y="5" width="18" height="14" rx="2"/><path d="M7 9h10M7 13h6"/></svg></div><h3>Plaques & gravures</h3><p>Exercitation ullamco laboris nisi ut aliquip ex ea.</p></div>
      </div>
    </div>
  </section>

  <CtaBand title="Un conseil pour choisir avec soin." text="Nos conseillers vous présentent nos articles funéraires et vous guident sans précipitation." phone="Permanence 24h/24" phoneHref={site.pf.phoneHref} />
</Base>
