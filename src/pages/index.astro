---
// PORTAIL D'ACCUEIL — page racine "/" qui laisse le visiteur choisir son univers :
//   • Pôle santé  → /ambulances        (charte bleue, ECG, Star of Life)
//   • Pôle funéraire → /pompes-funebres (charte violet aubergine / or, arbre de vie)
// Page volontairement AUTONOME (pas de Base.astro) : ni header ni footer de pôle,
// pour rester neutre entre les deux marques du groupe.
import { site } from '../data/site.js';
import logo from '../assets/logo-440w.webp';

const title = 'Ambulances Doré & Pompes Funèbres Jenna — Blois (Loir-et-Cher)';
const description =
  "Le groupe Doré à Blois : Ambulances Doré (ambulance, VSL, taxi conventionné, transport PMR, 24h/24) et Pompes Funèbres Jenna (organisation d'obsèques, contrat obsèques, marbrerie). Choisissez votre pôle.";
const canonical = site.domain + '/';
---

<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonical} />
  <meta property="og:type" content="website" />
  <meta property="og:locale" content="fr_FR" />
  <meta property="og:site_name" content="Ambulances Doré" />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonical} />
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="theme-color" content="#001f4d" />
  <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Comfortaa:wght@400;500;600;700&family=Cormorant+Garamond:ital,wght@0,500;0,600;0,700;1,500;1,600&family=Montserrat:wght@500;600;700;800;900&display=swap"
    rel="stylesheet"
  />
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "Groupe Doré",
    "url": site.domain,
    "subOrganization": [
      { "@type": "EmergencyService", "name": "Ambulances Doré", "url": site.domain + "/ambulances", "telephone": "+33254781555" },
      { "@type": "FuneralHome", "name": site.pf.name, "url": site.domain + "/pompes-funebres", "telephone": "+33279400272" }
    ]
  })} />
</head>

<body class="portal-body">
  <main class="portal">
    <header class="portal-top">
      <img class="portal-logo" src={logo.src} width={logo.width} height={logo.height} alt="Ambulances Doré" />
      <p class="portal-kicker">La Chaussée-Saint-Victor · Oucques · Blois — depuis 2007</p>
      <h1 class="portal-h1">Bienvenue. <span>Quel accompagnement recherchez-vous ?</span></h1>
    </header>

    <div class="portal-doors">
      <!-- PORTE AMBULANCES -->
      <a class="door door-amb" href="/ambulances">
        <span class="door-photo" style="background-image:url('/images/ambulance-route.webp')" aria-hidden="true"></span>
        <span class="door-veil" aria-hidden="true"></span>
        <span class="door-ecg" aria-hidden="true">
          <svg viewBox="0 0 600 40" preserveAspectRatio="none"><path d="M0,20 L210,20 L218,6 L226,34 L234,3 L242,37 L250,20 L420,20 L428,8 L436,32 L444,5 L452,35 L460,20 L600,20" /></svg>
        </span>
        <span class="door-inner">
          <span class="door-ico" aria-hidden="true">
            <svg viewBox="0 0 100 100"><path d="M74 50 L94.11 38.39 L82.11 17.61 L62 29.22 L62 6 L38 6 L38 29.22 L17.89 17.61 L5.89 38.39 L26 50 L5.89 61.61 L17.89 82.39 L38 70.78 L38 94 L62 94 L62 70.78 L82.11 82.39 L94.11 61.61 Z" /></svg>
          </span>
          <span class="door-eyebrow">Pôle santé</span>
          <span class="door-title">Ambulances Doré</span>
          <span class="door-desc">Ambulance, VSL, taxi conventionné, transport PMR &amp; mission SAMU. Disponibles 24h/24, 7j/7 dans le Loir-et-Cher.</span>
          <span class="door-cta">
            Entrer
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M5 12h14M13 6l6 6-6 6" /></svg>
          </span>
          <span class="door-phone">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.37 1.9.72 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.35 1.85.59 2.81.72A2 2 0 0 1 22 16.92Z" /></svg>
            {site.phoneMain}
          </span>
        </span>
      </a>

      <!-- PORTE POMPES FUNÈBRES -->
      <a class="door door-pf" href="/pompes-funebres">
        <span class="door-tree" aria-hidden="true"></span>
        <span class="door-inner">
          <span class="door-ico door-ico-tree" aria-hidden="true"></span>
          <span class="door-eyebrow">Pôle funéraire</span>
          <span class="door-title">Pompes Funèbres Jenna</span>
          <span class="door-slogan">L'art du funéraire, c'est l'art du détail</span>
          <span class="door-desc">Organisation d'obsèques, contrat de prévoyance, marbrerie &amp; articles funéraires. Une agence de proximité à Blois.</span>
          <span class="door-cta">
            Entrer
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M5 12h14M13 6l6 6-6 6" /></svg>
          </span>
          <span class="door-phone">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.13.96.37 1.9.72 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.91.35 1.85.59 2.81.72A2 2 0 0 1 22 16.92Z" /></svg>
            {site.pf.phone}
          </span>
        </span>
      </a>
    </div>

    <footer class="portal-foot">
      <span>© 2026 Groupe Doré — Ambulances Doré &amp; Pompes Funèbres Jenna</span>
      <span class="portal-foot-links">
        <a href="/contact">Contact</a>
        <a href="/mentions-legales">Mentions légales</a>
        <a href="/vie-privee">Vie privée</a>
      </span>
    </footer>
  </main>
</body>
</html>

<style>
  :root {
    --amb-1: #0c76f4;
    --amb-2: #00398c;
    --amb-3: #001f4d;
    --pf-1: #3a2150;
    --pf-2: #2a1638;
    --pf-3: #1b0e29;
    --gold: #b8893d;
    --gold-soft: #e6c477;
    --ivory: #f3ede2;
  }

  * { box-sizing: border-box; }

  .portal-body {
    margin: 0;
    min-height: 100vh;
    min-height: 100dvh;
    font-family: 'Montserrat', system-ui, sans-serif;
    color: #fff;
    background: #0a1530;
    -webkit-font-smoothing: antialiased;
    overflow-x: hidden;
  }

  .portal {
    min-height: 100vh;
    min-height: 100dvh;
    display: flex;
    flex-direction: column;
  }

  /* ---- En-tête ---- */
  .portal-top {
    text-align: center;
    padding: clamp(22px, 4vh, 46px) 20px clamp(14px, 2.4vh, 26px);
    position: relative;
    z-index: 3;
  }
  .portal-logo {
    height: clamp(46px, 7vh, 70px);
    width: auto;
    filter: drop-shadow(0 6px 20px rgba(0,0,0,.4));
  }
  .portal-kicker {
    margin: 14px 0 0;
    font-size: clamp(10px, 1.4vw, 12px);
    letter-spacing: .22em;
    text-transform: uppercase;
    color: rgba(255,255,255,.62);
    font-weight: 600;
  }
  .portal-h1 {
    margin: 10px auto 0;
    max-width: 640px;
    font-size: clamp(20px, 3.2vw, 30px);
    font-weight: 700;
    line-height: 1.25;
  }
  .portal-h1 span {
    display: block;
    font-family: 'Cormorant Garamond', serif;
    font-style: italic;
    font-weight: 500;
    color: var(--gold-soft);
    font-size: clamp(20px, 3.4vw, 32px);
    margin-top: 2px;
  }

  /* ---- Les 2 portes ---- */
  .portal-doors {
    flex: 1;
    display: flex;
    gap: 0;
    min-height: 0;
  }
  .door {
    position: relative;
    flex: 1;
    overflow: hidden;
    text-decoration: none;
    color: #fff;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: clamp(28px, 5vw, 64px);
    transition: flex .55s cubic-bezier(.4,0,.2,1);
    isolation: isolate;
  }
  .door-amb { background: linear-gradient(160deg, var(--amb-1), var(--amb-2) 55%, var(--amb-3)); }
  .door-pf  { background: linear-gradient(160deg, var(--pf-1), var(--pf-2) 55%, var(--pf-3)); }

  /* desktop : la porte survolée s'agrandit doucement */
  @media (hover:hover) and (min-width: 861px) {
    .portal-doors:hover .door { flex: .82; }
    .portal-doors .door:hover { flex: 1.36; }
  }

  /* photo de fond (ambulances) */
  .door-photo {
    position: absolute; inset: 0;
    background-size: cover; background-position: center;
    opacity: .26;
    transform: scale(1.06);
    transition: opacity .55s ease, transform 6s ease;
    z-index: -2;
  }
  .door-amb:hover .door-photo { opacity: .4; transform: scale(1.12); }
  .door-veil {
    position: absolute; inset: 0; z-index: -1;
    background: linear-gradient(160deg, rgba(12,118,244,.55), rgba(0,31,77,.82));
  }

  /* ligne ECG bas de la porte santé */
  .door-ecg {
    position: absolute; left: 0; right: 0; bottom: 8%;
    height: 40px; opacity: .35; z-index: 0;
    color: var(--amb-1);
  }
  .door-ecg svg { width: 100%; height: 100%; }
  .door-ecg path { fill: none; stroke: #8fc1ff; stroke-width: 2; }

  /* arbre de vie en filigrane (funéraire) */
  .door-tree {
    position: absolute; inset: 0; z-index: 0;
    background: var(--gold);
    opacity: .12;
    -webkit-mask: url('/images/pf/arbre-de-vie.png') no-repeat center / 78% auto;
    mask: url('/images/pf/arbre-de-vie.png') no-repeat center / 78% auto;
    transition: opacity .55s ease;
  }
  .door-pf:hover .door-tree { opacity: .18; }

  .door-inner {
    position: relative; z-index: 2;
    max-width: 440px;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    transform: translateY(0);
    transition: transform .5s ease;
  }
  .door:hover .door-inner { transform: translateY(-4px); }

  .door-ico {
    width: clamp(46px, 6vw, 62px);
    height: clamp(46px, 6vw, 62px);
    margin-bottom: 20px;
    display: grid; place-items: center;
    border-radius: 50%;
    border: 1.5px solid rgba(255,255,255,.4);
    padding: 13px;
  }
  .door-amb .door-ico svg { width: 100%; height: 100%; fill: #fff; }
  .door-pf .door-ico-tree {
    border-color: rgba(230,196,119,.55);
    background: var(--gold-soft);
    -webkit-mask: url('/images/pf/arbre-de-vie.png') no-repeat center / 70% auto;
    mask: url('/images/pf/arbre-de-vie.png') no-repeat center / 70% auto;
    padding: 0;
  }
  /* la pastille de l'arbre est dessinée directement par le mask sur fond doré */
  .door-pf .door-ico-tree { background: var(--gold-soft); border: 1.5px solid rgba(230,196,119,.45); }

  .door-eyebrow {
    font-size: 11px; letter-spacing: .26em; text-transform: uppercase;
    font-weight: 700;
    color: rgba(255,255,255,.7);
  }
  .door-pf .door-eyebrow { color: var(--gold-soft); }

  .door-title {
    margin-top: 10px;
    font-size: clamp(26px, 3.6vw, 40px);
    font-weight: 800;
    line-height: 1.1;
  }
  .door-pf .door-title {
    font-family: 'Cormorant Garamond', serif;
    font-weight: 700;
    letter-spacing: .01em;
  }
  .door-slogan {
    margin-top: 8px;
    font-family: 'Cormorant Garamond', serif;
    font-style: italic;
    font-size: clamp(15px, 2vw, 19px);
    color: var(--gold-soft);
  }
  .door-desc {
    margin-top: 14px;
    font-size: clamp(13px, 1.5vw, 15px);
    line-height: 1.6;
    color: rgba(255,255,255,.82);
    max-width: 360px;
  }

  .door-cta {
    margin-top: 26px;
    display: inline-flex; align-items: center; gap: 10px;
    padding: 14px 30px;
    border-radius: 999px;
    font-weight: 700;
    font-size: 14px;
    letter-spacing: .02em;
    background: #fff;
    color: var(--amb-2);
    box-shadow: 0 12px 30px rgba(0,0,0,.28);
    transition: gap .3s ease, transform .3s ease;
  }
  .door-cta svg { width: 16px; height: 16px; }
  .door-pf .door-cta {
    background: linear-gradient(135deg, var(--gold-soft), var(--gold));
    color: var(--pf-3);
    font-family: 'Cormorant Garamond', serif;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: .12em;
    font-size: 15px;
  }
  .door:hover .door-cta { gap: 16px; }

  .door-phone {
    margin-top: 18px;
    display: inline-flex; align-items: center; gap: 8px;
    font-size: 14px; font-weight: 600;
    color: rgba(255,255,255,.78);
  }
  .door-phone svg { width: 15px; height: 15px; }

  /* séparateur lumineux entre les portes (desktop) */
  .portal-doors::after {
    content: '';
    position: absolute;
    pointer-events: none;
  }
  .door-pf { box-shadow: inset 1px 0 0 rgba(255,255,255,.08); }

  /* ---- Pied ---- */
  .portal-foot {
    z-index: 3;
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    align-items: center;
    gap: 8px 22px;
    padding: 16px 20px;
    font-size: 12px;
    color: rgba(255,255,255,.5);
    background: #0a1530;
    text-align: center;
  }
  .portal-foot-links { display: inline-flex; gap: 18px; flex-wrap: wrap; justify-content: center; }
  .portal-foot a { color: rgba(255,255,255,.65); text-decoration: none; }
  .portal-foot a:hover { color: #fff; text-decoration: underline; }

  /* ---- Mobile : empilé ---- */
  @media (max-width: 860px) {
    .portal-doors { flex-direction: column; }
    .door { padding: 38px 24px; min-height: 46vh; }
    .door-desc { display: none; }
    .door-ecg { bottom: 4%; }
    .door-inner { transform: none !important; }
  }

  @media (prefers-reduced-motion: reduce) {
    .door, .door-inner, .door-cta, .door-photo, .door-tree { transition: none; }
  }
</style>
</content>
