---
import Base from '../layouts/Base.astro';
import PageHero from '../components/PageHero.astro';
import { site } from '../data/site.js';

const title = 'Mentions légales | Ambulances Doré';
const description = "Mentions légales du site Ambulances Doré : éditeur, hébergeur, propriété intellectuelle et coordonnées de l'entreprise.";
---
<Base title={title} description={description} current="/mentions-legales">
  <PageHero
    eyebrow="Informations"
    title="Mentions <em>légales</em>."
    crumbs={[{ label: 'Mentions légales' }]}
  />

  <section class="section plain">
    <div class="container">
      <div class="prose" style="max-width:820px;margin:0 auto" data-reveal>
        <h2>Éditeur du site</h2>
        <p>
          {site.legal.raisonSociale}<br />
          {site.addressMain.street}, {site.addressMain.zip} {site.addressMain.city}<br />
          Téléphone : {site.phoneMain}<br />
          E-mail : {site.emailLegal}<br />
          Capital social : {site.legal.capital}<br />
          SIRET : {site.legal.siret}<br />
          N° TVA intracommunautaire : {site.legal.tva}<br />
          Directeur de la publication : {site.legal.raisonSociale}
        </p>

        <h3>Hébergement</h3>
        <p>Le site est hébergé par {site.legal.hebergeur}.</p>

        <h3>Propriété intellectuelle</h3>
        <p>L'ensemble des contenus présents sur ce site (textes, images, logos, éléments graphiques) est protégé par le droit de la propriété intellectuelle. Toute reproduction, représentation ou diffusion, totale ou partielle, sans autorisation préalable, est interdite.</p>

        <h3>Responsabilité</h3>
        <p>Les informations diffusées sur ce site sont fournies à titre indicatif. {site.legal.raisonSociale} s'efforce d'en assurer l'exactitude mais ne saurait être tenue responsable des erreurs ou omissions, ni de l'usage qui en serait fait.</p>

        <h3>Liens hypertextes</h3>
        <p>Ce site peut contenir des liens vers d'autres sites. {site.legal.raisonSociale} n'exerce aucun contrôle sur ces sites et décline toute responsabilité quant à leur contenu.</p>

        <h3>Données personnelles</h3>
        <p>Pour en savoir plus sur le traitement de vos données, consultez notre <a href="/vie-privee" style="color:var(--blue-deep);font-weight:700">politique de confidentialité</a>.</p>

        <p style="margin-top:30px;font-size:13px;color:var(--ink-soft)"><!-- TODO_CLIENT : valider la raison sociale exacte (Ambulances Doré), le gérant (Tarik Zemali) et compléter le titre professionnel / autorisation ARS si nécessaire. --></p>
      </div>
    </div>
  </section>
</Base>
